{
  "name": "videocanvas",
  "version": "1.0.0",
  "description": "TypeScript SDK for video composition and rendering",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./react": {
      "import": "./dist/react/index.mjs",
      "types": "./dist/react/index.d.mts"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "preview": "npm run build && node examples/preview/server.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "video",
    "editor",
    "timeline",
    "sdk",
    "typescript",
    "media"
  ],
  "license": "Apache-2.0",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "jsdom": "^26.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsdown": "^0.20.3",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
